# Copy this file to .env and adjust as needed.

# Secret used to sign JWT access tokens. CHANGE THIS in production.
SECRET_KEY=change-me-to-a-long-random-string

# Access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Database URL. Defaults to a local SQLite file.
# For PostgreSQL: postgresql+psycopg://user:password@localhost:5432/abuladze
DATABASE_URL=sqlite:///./abuladze.db

# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default admin account created on first run (seed).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
